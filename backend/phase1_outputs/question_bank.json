        {
          "label_bn": "পুরুষ",
          "value": "male"
        },
        {
          "label_bn": "মহিলা",
          "value": "female"
        },
        {
          "label_bn": "বলতে চাই না",
          "value": "undisclosed"
        }
      ]
    },
    {
      "id": "q_location",
      "type": "cascade",
      "field": "location",
      "text_bn": "আপনি কোন এলাকায় থাকেন?",
