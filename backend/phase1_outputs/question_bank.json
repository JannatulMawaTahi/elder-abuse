  "intro_screens": [
    {
      "id": "welcome",
      "type": "welcome",
      "field": "started",
      "text_bn": "স্বাগতম। আমি আপনার সমস্যাটি বুঝতে কিছু সহজ প্রশ্ন করব। সব তথ্য গোপন রাখা হবে।",
      "buttons": [
        {
          "label_bn": "▶ শুরু করুন",
          "value": "start"
        }
      ]
    },
    {
      "id": "q_reporter",
      "type": "choice",
      "field": "reporter_type",
      "text_bn": "আপনি কি নিজে এই সমস্যার শিকার?",
      "options": [
        {
          "label_bn": "আমি নিজে",
          "value": "self"
        },
        {
          "label_bn": "অন্যের পক্ষে",
          "value": "third_party"
        }
      ]
    },
    {
      "id": "q_age",
      "type": "yes_no",
      "field": "is_elder",
      "text_bn": "ভুক্তভোগীর বয়স কি প্রায় ৬০ বছর বা তার বেশি?"
    },
    {
      "id": "q_gender",
      "type": "choice",
      "field": "gender",
      "text_bn": "ভুক্তভোগী কি পুরুষ না মহিলা?",
