      "step2_label_bn": "জেলা বেছে নিন",
      "source": "divisions"
    }
  ],
  "category_select": {
    "id": "q_problem",
    "type": "multi_select",
    "field": "selected_categories",
    "text_bn": "আপনার কী সমস্যা হচ্ছে? (একাধিক বেছে নিতে পারেন)",
    "hint_bn": "যেগুলো আপনার সাথে ঘটছে সেগুলোতে চাপ দিন।",
    "min_select": 1
  },
  "followups": {
    "physical": [
      {
        "id": "P1",
        "type": "yes_no",
        "text_bn": "গত ১২ মাসে কি আপনাকে মারধর, ধাক্কা, চড় বা লাথি দেওয়া হয়েছে?",
        "yes_weight": 2
      },
      {
        "id": "P2",
        "type": "yes_no",
        "text_bn": "আঘাতের কারণে কি কখনো ডাক্তার বা হাসপাতালে যেতে হয়েছে?",
        "yes_weight": 2,
        "escalates_severity": true
      }
    ],
    "verbal": [
      {
        "id": "V1",
        "type": "yes_no",
        "text_bn": "আপনাকে কি গালিগালাজ, অপমান, ভয় দেখানো বা হুমকি দেওয়া হয়?",
        "yes_weight": 2
      },
      {
        "id": "V2",
        "type": "yes_no",
        "text_bn": "আপনাকে কি একঘরে করে রাখা হয় বা \"বোঝা\" মনে করা হয়?",
        "yes_weight": 1
      }
    ],
    "financial": [
      {
        "id": "F1",
        "type": "yes_no",
        "text_bn": "আপনার অনুমতি ছাড়া কি কেউ আপনার টাকা, পেনশন বা বয়স্ক ভাতা নিয়ে নেয়?",
        "yes_weight": 2
      },
      {
        "id": "F2",
        "type": "yes_no",
        "text_bn": "আপনার অনুমতি ছাড়া কি জমি বা সম্পত্তি লিখে নেওয়া হয়েছে?",
        "yes_weight": 2,
        "escalates_severity": true
      }
    ],
    "neglect": [
      {
        "id": "N1",
        "type": "yes_no",
        "text_bn": "পরিবার কি ইচ্ছাকৃতভাবে আপনাকে খাবার, পানি বা যত্ন থেকে বঞ্চিত করে?",
        "yes_weight": 2
      },
      {
        "id": "N2",
        "type": "yes_no",
        "text_bn": "অসুস্থ হলে পরিবার কি ইচ্ছাকৃতভাবে চিকিৎসা বা ওষুধ দেয় না?",
        "yes_weight": 2,
        "escalates_severity": true
      }
    ],
    "abandonment": [
      {
        "id": "A1",
        "type": "yes_no",
        "text_bn": "আপনাকে কি বাড়ি থেকে বের করে দেওয়া হয়েছে?",
        "yes_weight": 2
      },
      {
        "id": "A2",
        "type": "yes_no",
        "text_bn": "আপনাকে কি দীর্ঘ সময় একা ফেলে রাখা হয় বা পরিবার খোঁজ নেয় না?",
        "yes_weight": 2
      }
    ],
    "murder": [
      {
        "id": "M1",
        "type": "yes_no",
        "text_bn": "নির্যাতনের কারণে কি ভুক্তভোগী মারা গেছেন?",
        "yes_weight": 3,
        "emergency": true,
        "emergency_action_bn": "জরুরি: এখনই ৯৯৯ নম্বরে কল করুন এবং নিকটস্থ থানায় জানান।"
