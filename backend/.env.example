# ════════════════════════════════════════════════════════════════
# Elder Abuse AI — Environment Variables (TEMPLATE)
# Copy this file as .env and fill in your real API keys
# ════════════════════════════════════════════════════════════════

# Groq Whisper API (free tier)
# Get key: https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Google Gemini Flash API (free tier)
# Get key: https://aistudio.google.com
GOOGLE_API_KEY=your_google_key_here

# Firebase (Phase 4)
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=

# Server config
HOST=0.0.0.0
PORT=8000
